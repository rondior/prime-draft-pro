{
  "manifest_version": 3,
  "name": "Prime Draft Pro",
  "version": "0.1.0",
  "description": "Premium commissioner-only offline draft board with ESPN, Yahoo, and Sleeper import.",
  "action": {
    "default_title": "Open Prime Draft Pro"
  },
  "permissions": ["storage", "cookies", "tabs"],
  "host_permissions": [
    "https://fantasy.espn.com/*",
    "https://lm-api-reads.fantasy.espn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
